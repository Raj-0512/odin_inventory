<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= item.game_name %></title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

<header class="navbar">
    <div class="logo">
        <img src="/images/watermelon.png">
        <span>Gamer</span>
    </div>

    <nav>
        <a href="/">Home</a>
        <a href="/items">Products</a>
        <a href="/categories">Categories</a>
    </nav>

    <div class="search">
        <input placeholder="Search products...">
        <button>Search</button>
    </div>
</header>

<main class="wrapper">

    <a href="/items" class="back-btn"><< Return to Games</a>

    <div class="detail-box">

        <div class="image-section">
            <div class="image-circle">
                <img src="<%= item.src %>" alt="">
            </div>
        </div>

        <div class="content-section">

            <div class="top-row">
                <h1><%= item.game_name %></h1>
                <span class="price">$<%= item.game_price %></span>
            </div>

            <span class="category-pill"><%= item.genre_name %></span>

            <p class="brand">Platform: <%= item.platform_name %></p>

            <p class="description"><%= item.description %></p>

            <p class="quantity">Quantity: <%= item.quantity %></p>

            <div class="action-buttons">
                <a href="/items/<%= item.game_id %>/edit" class="edit-btn">Edit</a>
                <form action="/items/<%= item.game_id %>/delete" method="POST">
                    <button class="delete-btn">Delete</button>
                </form>
            </div>

        </div>

    </div>

</main>


</body>
</html>
